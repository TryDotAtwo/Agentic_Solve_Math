# Primary OpenAI path
# OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter debug path
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional local g4f server auth. Leave unset if you want the auto-started
# local g4f API to run without authentication and use the client sentinel key
# from runtime_config.toml.
# G4F_API_KEY=your_local_g4f_api_key_here

# Optional compatibility routes that remain supported.
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Optional global override. Leave commented to keep per-agent model policy.
# ASM_OPENAI_MODEL=gpt-5.2

# Optional runtime overrides.
ASM_ROOT_MAX_TURNS=12
ASM_AUTO_INSTALL=1
# ASM_PROVIDER=openai
# ASM_OPEN_BROWSER=1
